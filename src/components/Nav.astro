---
import { BRAND, NAV } from "../lib/brand";
---
<header class="sticky top-0 z-40 backdrop-blur bg-ink/80 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-5 md:px-8 flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 group">
      <span class="w-8 h-8 rounded-full bg-rust grid place-items-center text-bone font-display font-black">H</span>
      <span class="font-display text-xl tracking-tight group-hover:text-rust transition">{BRAND.name}</span>
    </a>
    <nav class="hidden md:flex items-center gap-7 text-sm text-bone/80">
      {NAV.map((n) => (
        <a href={n.href} class="hover:text-bone transition">{n.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <a href="/shop" class="hidden sm:inline-flex btn btn-ghost !py-2 !px-4 !text-sm">Shop</a>
      <a href="/cart" aria-label="Cart" class="relative w-10 h-10 grid place-items-center rounded-full border border-white/10 hover:border-rust/50 transition">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 104 0 2 2 0 00-4 0zm-8 0a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        <span id="cart-count" class="absolute -top-1 -right-1 bg-rust text-white text-[10px] rounded-full w-5 h-5 grid place-items-center font-bold hidden">0</span>
      </a>
    </div>
  </div>
</header>
<script is:inline>
  (function(){
    function updateCount(){
      try{
        const cart = JSON.parse(localStorage.getItem('ht_cart')||'[]');
        const n = cart.reduce((a,b)=>a+(b.qty||0),0);
        const el = document.getElementById('cart-count');
        if(!el) return;
        if(n>0){ el.textContent = String(n); el.classList.remove('hidden'); }
        else { el.classList.add('hidden'); }
      }catch(e){}
    }
    updateCount();
    window.addEventListener('storage', updateCount);
    window.addEventListener('ht:cart', updateCount);
  })();
</script>
