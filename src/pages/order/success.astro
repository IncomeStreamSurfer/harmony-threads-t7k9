---
import Base from "../../layouts/Base.astro";
import { stripe } from "../../lib/stripe";
import { BRAND } from "../../lib/brand";

const sessionId = Astro.url.searchParams.get("session_id");
let ok = false;
let amount = 0;
let currency = "gbp";
let email = "";
let items: any[] = [];

if (sessionId && import.meta.env.STRIPE_SECRET_KEY) {
  try {
    const s = await stripe().checkout.sessions.retrieve(sessionId, { expand: ["line_items"] });
    ok = s.payment_status === "paid" || s.status === "complete";
    amount = s.amount_total || 0;
    currency = s.currency || "gbp";
    email = s.customer_details?.email || "";
    items = (s.line_items?.data ?? []).map((li: any) => ({ name: li.description, qty: li.quantity, price: li.price?.unit_amount }));
  } catch {}
}
const money = (p: number) => (currency === "gbp" ? "£" : "$") + (p / 100).toFixed(2);
---
<Base
  title={`Order confirmed | ${BRAND.name}`}
  description="Your Harmony Threads order is confirmed."
  noindex={true}
>
  <section class="max-w-3xl mx-auto px-5 md:px-8 py-24">
    <div class="text-center">
      <div class="w-20 h-20 mx-auto rounded-full bg-rust/15 grid place-items-center">
        <span class="text-rust text-4xl">✓</span>
      </div>
      <h1 class="font-display text-5xl mt-6">Thank you.</h1>
      <p class="mt-3 text-bone/70 text-lg">Your order is confirmed{email ? <> — we sent a receipt to <span class="text-bone">{email}</span>.</> : "."}</p>
    </div>

    {ok && items.length > 0 && (
      <div class="mt-12 bg-ink-2 border border-white/10 rounded-2xl p-6">
        <h2 class="font-display text-2xl">Order summary</h2>
        <div class="mt-4 divide-y divide-white/5">
          {items.map((it) => (
            <div class="py-3 flex justify-between text-sm">
              <div>
                <div class="font-semibold">{it.name}</div>
                <div class="text-bone/50">Qty {it.qty}</div>
              </div>
              <div class="text-bone/80">{money(it.price * it.qty)}</div>
            </div>
          ))}
          <div class="py-4 flex justify-between font-semibold text-lg">
            <span>Total</span><span>{money(amount)}</span>
          </div>
        </div>
      </div>
    )}

    <div class="mt-10 text-center">
      <a href="/shop" class="btn btn-primary">Keep shopping →</a>
      <p class="mt-6 text-xs text-bone/40">Questions? <a href="/contact" class="underline hover:text-rust">Get in touch</a>.</p>
    </div>
  </section>

  <script is:inline>
    localStorage.removeItem('ht_cart');
    window.dispatchEvent(new Event('ht:cart'));
  </script>
</Base>
