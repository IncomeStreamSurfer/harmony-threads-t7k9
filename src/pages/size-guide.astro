---
import Base from "../layouts/Base.astro";
import { BRAND } from "../lib/brand";

const chart = [
  { size: "Small (S)",   chest: "94–99",   length: "68", shoulder: "46" },
  { size: "Medium (M)",  chest: "99–104",  length: "71", shoulder: "48" },
  { size: "Large (L)",   chest: "104–109", length: "74", shoulder: "51" },
  { size: "X-Large (XL)",chest: "109–114", length: "76", shoulder: "54" },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
    { "@type": "ListItem", position: 2, name: "Size guide", item: (Astro.site?.toString() || "") + "size-guide" },
  ],
};
---
<Base
  title={`T-shirt size guide — unisex fit | ${BRAND.name}`}
  description="How our unisex graphic tees fit and how to measure for the right size. Includes chest, body length, and shoulder measurements for S–XL."
  structuredData={breadcrumb}
>
  <section class="max-w-4xl mx-auto px-5 md:px-8 py-16">
    <nav class="text-xs text-bone/40 mb-4">
      <a href="/" class="hover:text-rust">Home</a> <span class="mx-2">/</span>
      <a href="/collections/apparel" class="hover:text-rust">Apparel</a> <span class="mx-2">/</span>
      <span>Size guide</span>
    </nav>
    <h1 class="font-display text-5xl">T-shirt size guide.</h1>
    <p class="mt-4 text-bone/70 text-lg max-w-2xl">Our tees are unisex and deliberately slightly boxy. If you're between sizes, go down — the cotton softens and widens across the chest by about a centimetre after four or five washes.</p>

    <div class="mt-12 bg-ink-2 border border-white/10 rounded-2xl overflow-hidden">
      <table class="w-full">
        <thead class="bg-ink border-b border-white/10">
          <tr class="text-left text-xs uppercase tracking-widest text-bone/50">
            <th class="p-4">Size</th>
            <th class="p-4">Chest (cm)</th>
            <th class="p-4">Length (cm)</th>
            <th class="p-4">Shoulder (cm)</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-white/5">
          {chart.map((r) => (
            <tr>
              <td class="p-4 font-display text-lg">{r.size}</td>
              <td class="p-4 text-bone/70">{r.chest}</td>
              <td class="p-4 text-bone/70">{r.length}</td>
              <td class="p-4 text-bone/70">{r.shoulder}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-5">
      <div class="bg-ink-2 border border-white/10 rounded-2xl p-6">
        <h2 class="font-display text-2xl">How to measure</h2>
        <ol class="mt-3 list-decimal pl-5 text-bone/70 text-sm space-y-2">
          <li><strong>Chest:</strong> lay a t-shirt that fits you flat, measure armpit to armpit and double it.</li>
          <li><strong>Length:</strong> from the highest point of the shoulder to the hem.</li>
          <li><strong>Shoulder:</strong> seam to seam across the back.</li>
        </ol>
      </div>
      <div class="bg-ink-2 border border-white/10 rounded-2xl p-6">
        <h2 class="font-display text-2xl">The cut</h2>
        <p class="mt-3 text-bone/70 text-sm leading-relaxed">Drop shoulder with a 2cm sleeve roll. Hem falls about 2cm below the belt. Ribbed collar holds shape. 220gsm combed cotton — heavy, substantial, built to last.</p>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a href="/shop/the-band-graphic-tee" class="btn btn-primary">Shop the tee →</a>
    </div>
  </section>
</Base>
