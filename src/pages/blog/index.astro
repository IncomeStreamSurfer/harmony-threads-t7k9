---
import Base from "../../layouts/Base.astro";
import { listPublishedPosts } from "../../lib/supabase";
import { BRAND } from "../../lib/brand";

const posts = await listPublishedPosts();

const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
    { "@type": "ListItem", position: 2, name: "Journal", item: (Astro.site?.toString() || "") + "blog" },
  ],
};

const blogSchema = {
  "@context": "https://schema.org", "@type": "Blog",
  name: `Journal | ${BRAND.name}`,
  url: (Astro.site?.toString() || "") + "blog",
  description: "Essays, interviews and notes from inside the Harmony Threads studio.",
};
---
<Base
  title={`Journal — essays, interviews and notes | ${BRAND.name}`}
  description="The Harmony Threads journal. Essays about the records we grew up on, interviews with the musicians we wear on our chest, and notes from inside the studio."
  structuredData={[breadcrumb, blogSchema]}
>
  <section class="max-w-5xl mx-auto px-5 md:px-8 py-20">
    <nav class="text-xs text-bone/40 mb-4">
      <a href="/" class="hover:text-rust">Home</a> <span class="mx-2">/</span> <span>Journal</span>
    </nav>
    <h1 class="font-display text-5xl md:text-6xl">The journal.</h1>
    <p class="mt-4 text-bone/70 text-lg max-w-2xl">Essays, interviews, and studio notes. New pieces land here whenever we've got something worth saying.</p>
  </section>

  {posts.length === 0 ? (
    <section class="max-w-3xl mx-auto px-5 md:px-8 pb-24">
      <div class="bg-ink-2 border border-white/10 rounded-3xl p-10 md:p-14 text-center">
        <p class="text-xs uppercase tracking-[0.28em] text-rust font-semibold">Coming soon</p>
        <h2 class="font-display text-3xl md:text-4xl mt-3">Fresh articles arriving shortly.</h2>
        <p class="mt-4 text-bone/60 max-w-lg mx-auto">We're moving slowly on the journal — a few pieces a month, written properly. Join the list and we'll send you the first one when it's ready.</p>
        <form action="/api/subscribe" method="post" class="mt-8 max-w-md mx-auto flex gap-2">
          <input required type="email" name="email" placeholder="you@inbox.com" class="flex-1 bg-ink border border-white/10 rounded-full px-5 py-3 placeholder:text-bone/30 focus:border-rust outline-none"/>
          <button class="btn btn-primary" type="submit">Notify me</button>
        </form>
      </div>

      <div class="mt-16 grid md:grid-cols-3 gap-6">
        <a href="/collections/apparel" class="group bg-ink-2 border border-white/10 rounded-2xl p-6 hover:border-rust/50 transition">
          <p class="text-xs uppercase tracking-widest text-rust">Apparel</p>
          <h3 class="font-display text-xl mt-2 group-hover:text-rust transition">Shop the tees →</h3>
          <p class="text-sm text-bone/50 mt-2">Hand-printed music graphic apparel.</p>
        </a>
        <a href="/collections/books" class="group bg-ink-2 border border-white/10 rounded-2xl p-6 hover:border-rust/50 transition">
          <p class="text-xs uppercase tracking-widest text-rust">Books</p>
          <h3 class="font-display text-xl mt-2 group-hover:text-rust transition">Read the history →</h3>
          <p class="text-sm text-bone/50 mt-2">Deep-dive music books and audiobooks.</p>
        </a>
        <a href="/collections/fragrance" class="group bg-ink-2 border border-white/10 rounded-2xl p-6 hover:border-rust/50 transition">
          <p class="text-xs uppercase tracking-widest text-rust">Fragrance</p>
          <h3 class="font-display text-xl mt-2 group-hover:text-rust transition">Smell the shop →</h3>
          <p class="text-sm text-bone/50 mt-2">Small-batch unisex perfume from Grasse.</p>
        </a>
      </div>
    </section>
  ) : (
    <section class="max-w-5xl mx-auto px-5 md:px-8 pb-24 grid md:grid-cols-2 gap-6">
      {posts.map((p: any) => (
        <a href={`/blog/${p.slug}`} class="group bg-ink-2 border border-white/10 rounded-2xl overflow-hidden hover:border-rust/50 transition">
          {p.cover_image_url && <img src={p.cover_image_url} alt={p.title} class="w-full aspect-[16/10] object-cover"/>}
          <div class="p-6">
            <p class="text-xs uppercase tracking-widest text-bone/40">{new Date(p.published_at).toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" })}</p>
            <h2 class="font-display text-2xl mt-2 group-hover:text-rust">{p.title}</h2>
            {p.excerpt && <p class="mt-3 text-bone/60 text-sm line-clamp-3">{p.excerpt}</p>}
          </div>
        </a>
      ))}
    </section>
  )}
</Base>
