---
import Base from "../layouts/Base.astro";
import { BRAND } from "../lib/brand";

const sent = Astro.url.searchParams.get("sent") === "1";

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  url: (Astro.site?.toString() || "") + "contact",
  name: `Contact | ${BRAND.name}`,
  mainEntity: {
    "@type": "Organization", name: BRAND.name, email: BRAND.email, telephone: BRAND.phone,
    address: { "@type": "PostalAddress", streetAddress: BRAND.address.street, addressLocality: BRAND.address.city, postalCode: BRAND.address.postcode, addressCountry: BRAND.address.country },
  },
};

const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
    { "@type": "ListItem", position: 2, name: "Contact", item: (Astro.site?.toString() || "") + "contact" },
  ],
};
---
<Base
  title={`Contact — questions, press & wholesale | ${BRAND.name}`}
  description={`Get in touch with ${BRAND.name}. Questions about orders, press enquiries, wholesale, and general hellos — we reply within a working day.`}
  structuredData={[breadcrumb, contactSchema]}
>
  <section class="max-w-5xl mx-auto px-5 md:px-8 py-20 grid md:grid-cols-2 gap-16">
    <div>
      <nav class="text-xs text-bone/40 mb-4">
        <a href="/" class="hover:text-rust">Home</a> <span class="mx-2">/</span> <span>Contact</span>
      </nav>
      <h1 class="font-display text-5xl md:text-6xl">Talk to us.</h1>
      <p class="mt-4 text-bone/70 text-lg">Questions, press, wholesale, or just a hello — we reply within a working day.</p>

      <div class="mt-10 space-y-6 text-bone/80">
        <div>
          <p class="text-xs uppercase tracking-widest text-rust font-semibold mb-1">Email</p>
          <a href={`mailto:${BRAND.email}`} class="font-display text-2xl hover:text-rust">{BRAND.email}</a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-rust font-semibold mb-1">Phone</p>
          <a href={`tel:${BRAND.phone.replace(/\s/g,'')}`} class="font-display text-2xl hover:text-rust">{BRAND.phone}</a>
          <p class="text-sm text-bone/50 mt-1">Mon–Fri, 10:00–18:00 GMT</p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-widest text-rust font-semibold mb-1">Visit</p>
          <address class="not-italic font-display text-xl">
            {BRAND.address.street}<br/>
            {BRAND.address.city}, {BRAND.address.postcode}<br/>
            {BRAND.address.country}
          </address>
          <a href="https://maps.google.com/?q=Broadway+Market+London+E2" target="_blank" rel="noopener" class="mt-2 inline-block text-sm text-bone/60 hover:text-rust">View on Google Maps ↗</a>
        </div>
      </div>
    </div>

    <div>
      <form method="post" action="/api/contact" class="bg-ink-2 border border-white/10 rounded-2xl p-8 space-y-5">
        {sent && (
          <div class="bg-rust/15 border border-rust/30 rounded-xl p-4 text-sm text-bone">
            Thanks — we got your note. We'll reply within a working day.
          </div>
        )}
        <div>
          <label for="name" class="text-xs uppercase tracking-widest text-bone/60">Your name</label>
          <input id="name" name="name" required class="mt-2 w-full bg-ink border border-white/10 rounded-xl px-4 py-3 focus:border-rust outline-none"/>
        </div>
        <div>
          <label for="email" class="text-xs uppercase tracking-widest text-bone/60">Email</label>
          <input id="email" type="email" name="email" required class="mt-2 w-full bg-ink border border-white/10 rounded-xl px-4 py-3 focus:border-rust outline-none"/>
        </div>
        <div>
          <label for="message" class="text-xs uppercase tracking-widest text-bone/60">Message</label>
          <textarea id="message" name="message" rows="5" required class="mt-2 w-full bg-ink border border-white/10 rounded-xl px-4 py-3 focus:border-rust outline-none"></textarea>
        </div>
        <button class="btn btn-primary w-full !h-12" type="submit">Send message →</button>
        <p class="text-xs text-bone/40 text-center">By submitting, you agree to our <a href="/privacy" class="underline hover:text-rust">privacy policy</a>.</p>
      </form>
    </div>
  </section>
</Base>
