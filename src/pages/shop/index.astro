---
import Base from "../../layouts/Base.astro";
import ProductCard from "../../components/ProductCard.astro";
import { allProducts, COLLECTIONS } from "../../lib/catalog";
import { BRAND } from "../../lib/brand";

const products = await allProducts();

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
    { "@type": "ListItem", position: 2, name: "Shop", item: (Astro.site?.toString() || "") + "shop" },
  ],
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Shop — " + BRAND.name,
  url: (Astro.site?.toString() || "") + "shop",
  hasPart: products.map((p) => ({
    "@type": "Product",
    name: p.name,
    url: (Astro.site?.toString() || "") + "shop/" + p.slug,
    image: p.image_url,
    offers: { "@type": "Offer", price: (p.price_pence / 100).toFixed(2), priceCurrency: "GBP", availability: "https://schema.org/InStock" },
  })),
};
---
<Base
  title={`Shop all products | ${BRAND.name}`}
  description="Browse every piece at Harmony Threads — hand-printed music apparel, deep-dive music books and audiobooks, and small-batch fragrance. Free UK delivery over £50."
  structuredData={[breadcrumb, collectionSchema]}
>
  <section class="border-b border-white/5 bg-ink-2">
    <div class="max-w-7xl mx-auto px-5 md:px-8 py-16">
      <nav class="text-xs text-bone/40 mb-4">
        <a href="/" class="hover:text-rust">Home</a> <span class="mx-2">/</span> <span>Shop</span>
      </nav>
      <h1 class="font-display text-5xl md:text-6xl">Shop all products.</h1>
      <p class="mt-3 text-bone/70 max-w-2xl">Everything we make, in one place. Apparel, books, fragrance — the common thread is music, the common standard is <em>we'd own it ourselves</em>.</p>
      <div class="mt-8 flex flex-wrap gap-2">
        <a href="/shop" class="text-xs uppercase tracking-widest px-4 py-2 rounded-full bg-rust text-white">All ({products.length})</a>
        {COLLECTIONS.map((c) => (
          <a href={`/collections/${c.slug}`} class="text-xs uppercase tracking-widest px-4 py-2 rounded-full border border-white/10 hover:border-rust hover:text-rust transition">{c.name}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-5 md:px-8 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {products.map((p) => <ProductCard p={p} />)}
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-5 md:px-8 py-20 text-center border-t border-white/5">
    <h2 class="font-display text-3xl md:text-4xl">Want something we don't make yet?</h2>
    <p class="mt-4 text-bone/70">We take requests seriously. Drop us a note — if enough of you want it, we'll try to make it.</p>
    <a href="/contact" class="mt-6 inline-flex btn btn-ghost">Get in touch →</a>
  </section>
</Base>
