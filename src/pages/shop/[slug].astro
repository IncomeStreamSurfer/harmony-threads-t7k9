---
import Base from "../../layouts/Base.astro";
import ProductCard from "../../components/ProductCard.astro";
import { productBySlug, allProducts, formatGBP, minPricePence } from "../../lib/catalog";
import { BRAND } from "../../lib/brand";

const { slug } = Astro.params as { slug: string };
const p = await productBySlug(slug);
if (!p) return Astro.redirect("/shop");

const all = await allProducts();
const related = all.filter((x) => x.slug !== p.slug).slice(0, 3);

const sizes = Array.from(new Set(p.variants.map((v) => v.size).filter(Boolean))) as string[];
const colors = Array.from(new Set(p.variants.map((v) => v.color).filter(Boolean))) as string[];
const hasColor = colors.length > 0;
const hasSize = sizes.length > 0;

const productSchema = {
  "@context": "https://schema.org", "@type": "Product",
  name: p.name, description: p.description,
  image: [p.image_url, ...(p.gallery || [])].filter(Boolean),
  brand: { "@type": "Brand", name: p.vendor || BRAND.name },
  sku: p.variants[0]?.sku,
  offers: {
    "@type": "AggregateOffer", priceCurrency: p.currency,
    lowPrice: (minPricePence(p) / 100).toFixed(2),
    highPrice: (Math.max(...p.variants.map((v) => v.price_pence ?? p.price_pence)) / 100).toFixed(2),
    offerCount: p.variants.length,
    availability: "https://schema.org/InStock",
    seller: { "@type": "Organization", name: BRAND.name },
  },
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "127" },
};

const breadcrumb = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: Astro.site?.toString() },
    { "@type": "ListItem", position: 2, name: "Shop", item: (Astro.site?.toString() || "") + "shop" },
    { "@type": "ListItem", position: 3, name: p.name, item: (Astro.site?.toString() || "") + "shop/" + p.slug },
  ],
};

const colorHex: Record<string, string> = {
  "Forest Green": "#2f4a2a", "Heather Gray": "#9ca3af", "Faded Red": "#b04430",
};

const gallery = ([p.image_url, ...(p.gallery || [])].filter(Boolean) as string[]).filter((x, i, a) => a.indexOf(x) === i);
---
<Base
  title={p.seo_title || `${p.name} | ${BRAND.name}`}
  description={p.seo_description || p.description || BRAND.description}
  ogImage={p.image_url || undefined}
  ogType="product"
  structuredData={[breadcrumb, productSchema]}
  tags={p.tags}
>
  <section class="max-w-7xl mx-auto px-5 md:px-8 pt-8 pb-6">
    <nav class="text-xs text-bone/40">
      <a href="/" class="hover:text-rust">Home</a> <span class="mx-2">/</span>
      <a href="/shop" class="hover:text-rust">Shop</a> <span class="mx-2">/</span>
      <span>{p.name}</span>
    </nav>
  </section>

  <section class="max-w-7xl mx-auto px-5 md:px-8 pb-16 grid lg:grid-cols-2 gap-12">
    <div>
      <div class="aspect-square rounded-2xl overflow-hidden bg-ink-2 border border-white/5">
        <img id="main-image" src={gallery[0]} alt={p.image_alt || p.name} class="w-full h-full object-cover"/>
      </div>
      {gallery.length > 1 && (
        <div class="mt-3 grid grid-cols-4 gap-3">
          {gallery.map((g) => (
            <button class="aspect-square rounded-xl overflow-hidden border border-white/10 hover:border-rust transition" data-img={g}>
              <img src={g} alt={p.image_alt || p.name} class="w-full h-full object-cover"/>
            </button>
          ))}
        </div>
      )}
    </div>

    <div>
      <p class="text-[11px] uppercase tracking-[0.24em] text-rust font-semibold">{p.vendor}</p>
      <h1 class="font-display text-4xl md:text-5xl mt-2 leading-tight">{p.name}</h1>
      {p.tagline && <p class="mt-2 text-bone/60 text-lg">{p.tagline}</p>}

      <div class="mt-6 flex items-baseline gap-3">
        <span id="price" class="font-display text-3xl">{formatGBP(minPricePence(p))}</span>
        {p.compare_at_pence && <span class="text-bone/40 line-through">{formatGBP(p.compare_at_pence)}</span>}
        {p.compare_at_pence && <span class="text-xs bg-rust/20 text-rust px-2 py-1 rounded-full font-semibold">Save {formatGBP(p.compare_at_pence - minPricePence(p))}</span>}
      </div>

      <p class="mt-6 text-bone/75 leading-relaxed">{p.description}</p>

      {hasSize && (
        <div class="mt-8">
          <p class="text-xs uppercase tracking-widest text-bone/50 mb-3">{sizes[0] && sizes[0].length > 3 ? "Format" : "Size"}</p>
          <div class="flex flex-wrap gap-2">
            {sizes.map((s, i) => (
              <button
                class={`variant-size px-4 py-2 rounded-full border text-sm transition ${i === 0 ? "bg-rust border-rust text-white" : "border-white/15 text-bone/80 hover:border-rust"}`}
                data-size={s}
              >{s}</button>
            ))}
          </div>
        </div>
      )}

      {hasColor && (
        <div class="mt-6">
          <p class="text-xs uppercase tracking-widest text-bone/50 mb-3">Colour: <span id="color-label" class="text-bone">{colors[0]}</span></p>
          <div class="flex flex-wrap gap-3">
            {colors.map((c, i) => (
              <button
                class={`variant-color w-10 h-10 rounded-full border-2 transition ${i === 0 ? "border-rust" : "border-white/20 hover:border-bone"}`}
                style={`background:${colorHex[c] ?? "#444"}`}
                data-color={c}
                aria-label={c}
                title={c}
              ></button>
            ))}
          </div>
        </div>
      )}

      <div class="mt-8 flex gap-3">
        <div class="flex items-center bg-ink-2 rounded-full border border-white/10 h-12">
          <button id="qty-dec" class="px-4 h-12 text-bone/60 hover:text-rust">−</button>
          <span id="qty" class="w-10 text-center font-semibold">1</span>
          <button id="qty-inc" class="px-4 h-12 text-bone/60 hover:text-rust">+</button>
        </div>
        <button id="add-to-cart" class="btn btn-primary flex-1 !h-12">Add to cart →</button>
      </div>
      <p class="mt-3 text-xs text-bone/50">{p.shipping_note}</p>

      {p.highlights && p.highlights.length > 0 && (
        <ul class="mt-8 grid grid-cols-1 gap-2 border-t border-white/5 pt-6">
          {p.highlights.map((h) => (
            <li class="flex gap-3 text-sm text-bone/75"><span class="text-rust">●</span> {h}</li>
          ))}
        </ul>
      )}
    </div>
  </section>

  {p.long_description && p.long_description.length > 0 && (
    <section class="bg-ink-2 border-y border-white/5 py-20">
      <div class="max-w-3xl mx-auto px-5 md:px-8">
        <h2 class="font-display text-3xl md:text-4xl">The story.</h2>
        <div class="mt-8 space-y-5 text-bone/80 leading-relaxed text-lg">
          {p.long_description.map((para) => (<p>{para}</p>))}
        </div>
        {p.care && p.care.length > 0 && (
          <div class="mt-12 bg-ink rounded-2xl border border-white/10 p-6">
            <h3 class="font-display text-xl">{p.type === "eBook" ? "Format details" : p.type === "Fragrance" ? "The details" : "Care"}</h3>
            <ul class="mt-4 space-y-2 text-sm text-bone/70">
              {p.care.map((c) => (<li>— {c}</li>))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 md:px-8 py-20">
      <h2 class="font-display text-3xl md:text-4xl mb-8">You might also like.</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {related.map((r) => <ProductCard p={r} />)}
      </div>
    </section>
  )}

  <script is:inline define:vars={{ variants: p.variants, productSlug: p.slug, productName: p.name, productImage: p.image_url, basePrice: p.price_pence }}>
    (function(){
      let selected = { size: variants.find(v=>v.size)?.size || null, color: variants.find(v=>v.color)?.color || null };
      let qty = 1;
      function currentVariant(){
        return variants.find(v => (selected.size ? v.size === selected.size : true) && (selected.color ? v.color === selected.color : true)) || variants[0];
      }
      function fmt(p){ return "£" + (p/100).toFixed(2); }
      function sync(){
        const v = currentVariant();
        const priceEl = document.getElementById('price');
        if (priceEl) priceEl.textContent = fmt(v.price_pence || basePrice);
        const colorLabel = document.getElementById('color-label');
        if (colorLabel && selected.color) colorLabel.textContent = selected.color;
        const mainImg = document.getElementById('main-image');
        if (mainImg && v.image_url) mainImg.setAttribute('src', v.image_url);
        const btn = document.getElementById('add-to-cart');
        if (btn) {
          if ((v.inventory ?? 0) <= 0 && v.inventory !== null && v.inventory < 9000) {
            btn.textContent = 'Sold out'; btn.setAttribute('disabled','true'); btn.classList.add('opacity-50');
          } else {
            btn.textContent = 'Add to cart →'; btn.removeAttribute('disabled'); btn.classList.remove('opacity-50');
          }
        }
      }
      document.querySelectorAll('.variant-size').forEach(el => {
        el.addEventListener('click', () => {
          selected.size = el.getAttribute('data-size');
          document.querySelectorAll('.variant-size').forEach(x => x.classList.remove('bg-rust','border-rust','text-white'));
          el.classList.add('bg-rust','border-rust','text-white');
          sync();
        });
      });
      document.querySelectorAll('.variant-color').forEach(el => {
        el.addEventListener('click', () => {
          selected.color = el.getAttribute('data-color');
          document.querySelectorAll('.variant-color').forEach(x => x.classList.remove('border-rust'));
          el.classList.add('border-rust');
          sync();
        });
      });
      document.querySelectorAll('[data-img]').forEach(el => {
        el.addEventListener('click', () => {
          const src = el.getAttribute('data-img');
          const mainImg = document.getElementById('main-image');
          if (mainImg && src) mainImg.setAttribute('src', src);
        });
      });
      document.getElementById('qty-dec')?.addEventListener('click', ()=>{ qty=Math.max(1, qty-1); const e=document.getElementById('qty'); if(e) e.textContent=String(qty); });
      document.getElementById('qty-inc')?.addEventListener('click', ()=>{ qty=qty+1; const e=document.getElementById('qty'); if(e) e.textContent=String(qty); });
      document.getElementById('add-to-cart')?.addEventListener('click', () => {
        const v = currentVariant();
        const cart = JSON.parse(localStorage.getItem('ht_cart')||'[]');
        const existing = cart.find(c => c.sku === v.sku);
        if (existing) existing.qty += qty;
        else cart.push({
          sku: v.sku, slug: productSlug, name: productName,
          variant: [v.size, v.color].filter(Boolean).join(' / '),
          price: v.price_pence || basePrice,
          image: v.image_url || productImage, qty,
        });
        localStorage.setItem('ht_cart', JSON.stringify(cart));
        window.dispatchEvent(new Event('ht:cart'));
        const btn = document.getElementById('add-to-cart');
        if (btn) { btn.textContent = 'Added ✓ — opening cart…'; setTimeout(()=>{ window.location.href='/cart'; }, 450); }
      });
      sync();
    })();
  </script>
</Base>
